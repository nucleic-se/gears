{
  "name": "@nucleic-se/gears",
  "version": "0.1.0",
  "description": "A specialized, modular agentic worker framework for Node.js.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nucleic-se/gears.git"
  },
  "bugs": {
    "url": "https://github.com/nucleic-se/gears/issues"
  },
  "homepage": "https://github.com/nucleic-se/gears#readme",
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./agentic": {
      "types": "./dist/src/agentic.d.ts",
      "import": "./dist/src/agentic.js"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    }
  },
  "bin": {
    "gears": "dist/src/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/src/cli/index.js work",
    "dev": "concurrently \"npm run watch\" \"npx nodemon --watch dist --delay 1 dist/src/cli/index.js work\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "clean": "rm -f test-*.sqlite* && rm -f .gears/test-*.sqlite*"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@nucleic-se/agentic": "^0.1.0",
    "better-sqlite3": "^12.6.2",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "json5": "^2.2.3",
    "kysely": "^0.28.11",
    "node-cron": "^4.2.1",
    "pino": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "undici": "^7.19.0"
  }
}
