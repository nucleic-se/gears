# ------------------------------------------------------------
# LLM Provider Selection
# ------------------------------------------------------------
# Which LLM backend to use (default: ollama)
# LLM_PROVIDER=ollama   # ollama | gemini | anthropic

# ------------------------------------------------------------
# LLM (Ollama)
# ------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Optional
# OLLAMA_API_KEY=your-api-key-here
# OLLAMA_EMBED_HOST=http://localhost:11434

# Notes
# - Ollama Cloud Pro host example: https://ollama.com
# - OLLAMA_EMBED_HOST falls back to OLLAMA_HOST when unset.

# ------------------------------------------------------------
# LLM (Google Gemini)
# ------------------------------------------------------------
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# ------------------------------------------------------------
# LLM (Anthropic Claude)
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_MAX_TOKENS=4096

# ------------------------------------------------------------
# Gears Core Paths and Storage
# ------------------------------------------------------------
# Optional (default: .gears/ in current directory)
# GEARS_DATA_DIR=/var/lib/gears

# Optional app DB path used by database bundle (default: app.sqlite)
# GEARS_APP_DB_PATH=app.sqlite

# ------------------------------------------------------------
# Scheduling and Worker
# ------------------------------------------------------------
# Optional timezone for cron scheduling (default: UTC)
# GEARS_TIMEZONE=Europe/Stockholm

# Optional worker settings (defaults shown)
# WORKER_CONCURRENCY=5
# WORKER_POLL_INTERVAL_MS=1000
# WORKER_RECOVERY_TIMEOUT_MS=300000
# WORKER_RECOVERY_CHECK_INTERVAL_MS=60000
# WORKER_HEARTBEAT_INTERVAL_MS=30000

# ------------------------------------------------------------
# Logging and Runtime
# ------------------------------------------------------------
# Optional (default: info)
# LOG_LEVEL=info

# Optional (common: development, production, test)
# NODE_ENV=development

# Optional advanced test/dev override (default: disabled)
# GEARS_ALLOW_ABSOLUTE_DB_PATHS=1
